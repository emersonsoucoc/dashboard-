{
  "name": "dashboard-agendaedu",
  "version": "1.0.0",
  "description": "Dashboard de performance de atendimentos - Agenda Edu",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "start:staging": "dotenv -e .env.staging -- node server.js",
    "start:prod": "dotenv -e .env.production -- node server.js",
    "dev:staging": "dotenv -e .env.staging -- nodemon server.js",
    "dev:prod": "dotenv -e .env.production -- nodemon server.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
